{
    "name": "whalewatcher (docker-in-docker)",
    "portsAttributes": {
        "16092": {
            "label": "whalewatcher package documentation",
            "onAutoForward": "notify",
            "protocol": "http"
        }
    },
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/node:2": {},
        "ghcr.io/devcontainers/features/go:1": {},
        "ghcr.io/thediveo/devcontainer-features/goreportcard:1": {},
        "ghcr.io/thediveo/devcontainer-features/go-mod-upgrade:1": {},
        "ghcr.io/thediveo/devcontainer-features/pinact:0": {},
        "ghcr.io/thediveo/devcontainer-features/lazygit:0": {},
        "ghcr.io/thediveo/devcontainer-features/gocover:1": {
            "root": true,
            "num-programs": "1",
            "race": true,
            "verbose": true,
            "html": true
        },
        "ghcr.io/thediveo/devcontainer-features/local-pkgsite:1": {
            "port": "16092"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:4": {
            "version": "latest",
            "moby": false // go for the upstream Docker-CE
        }
    },
    "remoteEnv": {
        "GOPATH": "/home/vscode/go",
        "PATH": "/home/vscode/go/bin:/go/bin:/usr/local/go/bin:${localEnv:PATH}"
    },
    "postCreateCommand": {
        "install-mockgen": "go install go.uber.org/mock/mockgen@latest",
        "go-for-root": "echo 'Defaults:vscode secure_path = \"/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/go/bin\"' | sudo tee -a /etc/sudoers.d/vscode"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dnut.rewrap-revived",
                "brunnerh.insert-unicode",
                "mhutchie.git-graph",
                "ms-vscode.live-server",
                "github.vscode-github-actions",
                "ms-vscode.makefile-tools"
            ]
        }
    }
}